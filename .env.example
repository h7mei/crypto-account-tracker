# Database
# Production: use sslmode=require in DATABASE_URL for managed Postgres (Neon, Supabase, etc.)
# Example: postgresql://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_tracker

# Server
PORT=3001

# JWT (generate a random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend (optional, for dev proxy)
VITE_API_URL=http://localhost:3001

# Optional - production
# CORS_ORIGIN=https://yourdomain.com
# DATABASE_POOL_SIZE=10
# NODE_ENV=production
